APP_NAME=using-mcp
APP_VERSION=v0.1.0

HTTP_PORT=9100
LOG_LEVEL=INFO
METRICS_PORT=2127

# Turns on the MCP server at /mcp. Two values are accepted:
#   true  – expose GET endpoints as MCP tools (safe default).
#   full  – also expose POST/PUT/PATCH/DELETE. Read this as
#           "I'm okay with the LLM mutating data via MCP."
MCP_ENABLED=full

# Where learned schemas are persisted between runs. Set to "-" to
# disable persistence entirely. Default ./.gofr-mcp-schemas.json.
# MCP_PERSIST_PATH=./.gofr-mcp-schemas.json
